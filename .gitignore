# ── Output / Results ──────────────────────────────────────────
output/
logs/
.snakemake/

# ── Data (project-specific, not tracked) ──────────────────────
data/raw/*.txt
data/raw/*.csv
data/raw/*.bed
data/raw/*.tsv
!data/raw/.gitkeep

# ── Project configs (track template only) ─────────────────────
configs/config_*.yml
!configs/template/config.yml

# ── R / Python artifacts ───────────────────────────────────────
*.Rhistory
*.RData
*.Rdata
*.pyc
__pycache__/

# ── HOMER output ───────────────────────────────────────────────
homerResults/
knownResults/
*.motif

# ── IDE / Editor ───────────────────────────────────────────────
*.code-workspace
.vscode/

# ── Claude Code (local settings only) ─────────────────────────
.claude/settings.local.json

# ── OS artifacts ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*:Zone.Identifier
